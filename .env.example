# Server Configuration
PORT=8080
DOMAIN=relay.example.com

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# ActivityPub Actor Configuration
# PRIVATE_KEY should be a Base64-encoded PEM private key.
# e.g., cat private.pem | base64 -w 0
PRIVATE_KEY=
ACTOR_USERNAME=relay

# Destination Mastodon Configuration
# The URL of the Mastodon instance to deliver activities to.
DESTINATION_URL=https://mastodon.example.com

# Filters (Comma-separated values)
FILTER_KEYWORDS=mastodon,activitypub
FILTER_HASHTAGS=relay,proxy

# Deduplication Cache TTL (e.g., 10m, 1h, 24h)
DEDUPLICATION_TTL=24h
